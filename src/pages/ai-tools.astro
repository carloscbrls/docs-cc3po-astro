---
import Layout from '../layouts/Layout.astro';

const title = "AI Tools for Small Business 2026 | CC3PO";
const description = "The best AI tools for small businesses in 2026. Automate marketing, customer service, content creation, and more.";
---

<Layout title={title} description={description}>
  <div class="container">
    <header>
      <h1>AI Tools for Small Business 2026</h1>
      <p class="subtitle">Automate marketing, customer service, content creation, and more</p>
    </header>

    <section class="intro">
      <p>AI tools can help small businesses automate repetitive tasks, improve customer service, and create content faster. Here's a curated list of the best tools available in 2026.</p>
    </section>

    <section class="category">
      <h2><span class="category-icon">📝</span> Content Creation</h2>
      
      <div class="tools-grid">
        <a href="https://chat.openai.com" class="tool-card" target="_blank" rel="noopener">
          <div class="tool-info">
            <h3>ChatGPT / Claude</h3>
            <p>AI assistants for writing, brainstorming, and content creation.</p>
          </div>
          <span class="tool-price">Free / $20/mo</span>
        </a>
        
        <a href="https://jasper.ai" class="tool-card" target="_blank" rel="noopener">
          <div class="tool-info">
            <h3>Jasper</h3>
            <p>Specialized AI for marketing content, blog posts, and social media.</p>
          </div>
          <span class="tool-price">From $39/mo</span>
        </a>
        
        <a href="https://copy.ai" class="tool-card" target="_blank" rel="noopener">
          <div class="tool-info">
            <h3>Copy.ai</h3>
            <p>AI-powered copywriting for ads, emails, and social posts.</p>
          </div>
          <span class="tool-price">Free / $49/mo</span>
        </a>
      </div>
    </section>

    <section class="category">
      <h2><span class="category-icon">🎨</span> Visual Content</h2>
      
      <div class="tools-grid">
        <a href="https://www.midjourney.com" class="tool-card" target="_blank" rel="noopener">
          <div class="tool-info">
            <h3>Midjourney</h3>
            <p>AI image generation for marketing materials and social media.</p>
          </div>
          <span class="tool-price">From $10/mo</span>
        </a>
        
        <a href="https://canva.com" class="tool-card" target="_blank" rel="noopener">
          <div class="tool-info">
            <h3>Canva + AI</h3>
            <p>Design platform with AI-powered features for quick graphics.</p>
          </div>
          <span class="tool-price">Free / $12.99/mo</span>
        </a>
      </div>
    </section>

    <section class="category">
      <h2><span class="category-icon">💬</span> Customer Service</h2>
      
      <div class="tools-grid">
        <a href="https://www.intercom.com" class="tool-card" target="_blank" rel="noopener">
          <div class="tool-info">
            <h3>Intercom</h3>
            <p>Customer messaging with AI-powered chatbots and automation.</p>
          </div>
          <span class="tool-price">From $74/mo</span>
        </a>
        
        <a href="https://crisp.chat" class="tool-card" target="_blank" rel="noopener">
          <div class="tool-info">
            <h3>Crisp</h3>
            <p>Live chat with AI assistant and shared inbox for teams.</p>
          </div>
          <span class="tool-price">Free / $25/mo</span>
        </a>
      </div>
    </section>

    <section class="category">
      <h2><span class="category-icon">📊</span> Business Operations</h2>
      
      <div class="tools-grid">
        <a href="https://zapier.com" class="tool-card" target="_blank" rel="noopener">
          <div class="tool-info">
            <h3>Zapier + AI</h3>
            <p>Automate workflows between apps with AI-powered actions.</p>
          </div>
          <span class="tool-price">Free / $19.99/mo</span>
        </a>
        
        <a href="https://notion.so" class="tool-card" target="_blank" rel="noopener">
          <div class="tool-info">
            <h3>Notion AI</h3>
            <p>Project management with built-in AI for writing and summarizing.</p>
          </div>
          <span class="tool-price">Free / $8/mo</span>
        </a>
      </div>
    </section>

    <section class="category">
      <h2><span class="category-icon">🔍</span> SEO & Marketing</h2>
      
      <div class="tools-grid">
        <a href="https://surferseo.com" class="tool-card" target="_blank" rel="noopener">
          <div class="tool-info">
            <h3>Surfer SEO</h3>
            <p>AI-powered content optimization for better search rankings.</p>
          </div>
          <span class="tool-price">From $89/mo</span>
        </a>
        
        <a href="https://www.semrush.com" class="tool-card" target="_blank" rel="noopener">
          <div class="tool-info">
            <h3>SEMrush + AI</h3>
            <p>Complete SEO toolkit with AI content and keyword features.</p>
          </div>
          <span class="tool-price">From $129.95/mo</span>
        </a>
      </div>
    </section>

    <section class="cta-section">
      <a href="https://offers.cc3po.com/agent-system.html" class="cta-button">Need AI Implementation? Get a Custom AI Agent System →</a>
    </section>
  </div>
</Layout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  
  header {
    text-align: center;
    padding: 3rem 0 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 2rem;
  }
  
  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  
  .subtitle {
    color: #a1a1aa;
    font-size: 1.1rem;
  }
  
  .intro {
    margin-bottom: 2rem;
    line-height: 1.8;
  }
  
  .category {
    margin-bottom: 2rem;
  }
  
  .category h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .category-icon {
    font-size: 1.5rem;
  }
  
  .tools-grid {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  
  .tool-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.2s ease;
    text-decoration: none;
    color: inherit;
  }
  
  .tool-card:hover {
    border-color: #6b35ff;
  }
  
  .tool-info h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }
  
  .tool-info p {
    color: #a1a1aa;
    font-size: 0.9rem;
  }
  
  .tool-price {
    background: #6b35ff;
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
    margin-left: 1rem;
  }
  
  .cta-section {
    margin-top: 3rem;
    text-align: center;
  }
  
  .cta-button {
    display: inline-block;
    background: linear-gradient(135deg, #6b35ff, #7c44ff);
    color: white;
    padding: 1rem 2rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s ease;
  }
  
  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(107, 53, 255, 0.3);
  }
</style>