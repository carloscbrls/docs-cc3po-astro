---
import Layout from '../layouts/Layout.astro';

const title = "Terms of Service | CC3PO Docs";
const description = "Terms of Service for CC3PO documentation and knowledge base.";
---

<Layout title={title}>
  <div class="legal-page">
    <h1>Terms of Service</h1>
    <p class="last-updated">Last Updated: April 23, 2026</p>
    
    <div class="legal-content">
      <section>
        <h2>1. Acceptance of Terms</h2>
        <p>By accessing and using the CC3PO documentation and knowledge base, you accept and agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use this documentation.</p>
      </section>
      
      <section>
        <h2>2. Use of Documentation</h2>
        <p>This documentation is provided for informational and educational purposes. You may:</p>
        <ul>
          <li>View and read the documentation for personal or professional use</li>
          <li>Share links to specific guides with attribution</li>
          <li>Apply the knowledge to your own projects and systems</li>
        </ul>
        <p>You may not:</p>
        <ul>
          <li>Copy or reproduce entire guides without permission</li>
          <li>Remove or alter copyright notices</li>
          <li>Use the documentation for commercial training without license</li>
        </ul>
      </section>
      
      <section>
        <h2>3. Content Accuracy</h2>
        <p>We strive to keep documentation accurate and up-to-date. However:</p>
        <ul>
          <li>Technical details may change without notice</li>
          <li>We do not guarantee all information is current</li>
          <li>Always verify with official sources before implementation</li>
        </ul>
      </section>
      
      <section>
        <h2>4. Disclaimer of Warranties</h2>
        <p>THE DOCUMENTATION IS PROVIDED "AS IS" WITHOUT WARRANTY OF ANY KIND. WE DISCLAIM ALL WARRANTIES, EXPRESS OR IMPLIED, INCLUDING:</p>
        <ul>
          <li>Merchantability and fitness for a particular purpose</li>
          <li>Accuracy, completeness, or reliability</li>
          <li>Non-infringement of intellectual property rights</li>
        </ul>
      </section>
      
      <section>
        <h2>5. Limitation of Liability</h2>
        <p>CC3PO shall not be liable for any damages arising from:</p>
        <ul>
          <li>Use or inability to use the documentation</li>
          <li>Errors or omissions in content</li>
          <li>Implementation of technical guidance</li>
          <li>Third-party tools or services referenced</li>
        </ul>
      </section>
      
      <section>
        <h2>6. Third-Party Links</h2>
        <p>Documentation may contain links to third-party websites, tools, or services. We are not responsible for:</p>
        <ul>
          <li>Content on third-party sites</li>
          <li>Privacy practices of external services</li>
          <li>Availability of external resources</li>
        </ul>
      </section>
      
      <section>
        <h2>7. Intellectual Property</h2>
        <p>All content in this documentation is owned by CC3PO unless otherwise stated. This includes:</p>
        <ul>
          <li>Text, graphics, and code examples</li>
          <li>Logos and branding</li>
          <li>Layout and design elements</li>
        </ul>
      </section>
      
      <section>
        <h2>8. Changes to Terms</h2>
        <p>We may update these Terms of Service at any time. Changes will be posted on this page with an updated "Last Updated" date.</p>
      </section>
      
      <section>
        <h2>9. Contact Information</h2>
        <p>For questions about these Terms of Service:</p>
        <ul>
          <li>Email: <a href="mailto:legal@cc3po.com">legal@cc3po.com</a></li>
          <li>Website: <a href="https://cc3po.com">cc3po.com</a></li>
        </ul>
      </section>
    </div>
    
    <div class="back-link">
      <a href="/">← Back to Knowledge Base</a>
    </div>
  </div>
</Layout>

<style>
  .legal-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 24px;
  }
  
  h1 {
    color: #6b35ff;
    font-size: 32px;
    margin-bottom: 8px;
  }
  
  .last-updated {
    color: #888;
    font-size: 14px;
    margin-bottom: 40px;
  }
  
  h2 {
    color: #1a1a2e;
    font-size: 20px;
    margin-top: 32px;
    margin-bottom: 12px;
  }
  
  p, li {
    color: #4a4a5a;
    line-height: 1.8;
  }
  
  ul {
    margin-left: 24px;
    margin-top: 8px;
  }
  
  li {
    margin-bottom: 8px;
  }
  
  a {
    color: #6b35ff;
    text-decoration: none;
  }
  
  a:hover {
    text-decoration: underline;
  }
  
  .back-link {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid rgba(107, 53, 255, 0.1);
  }
</style>